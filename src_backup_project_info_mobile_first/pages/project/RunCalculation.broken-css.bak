/* =========================
   SHIL Engineering Theme V2
   Mobile First
   ========================= */

:root{

  /* لایه 1 : پس زمینه */
  --shil-page-bg:#dce6eb;

  /* لایه 2 : کارت ها */
  --shil-card-bg:#edf4f7;

  /* لایه 3 : فیلدها */
  --shil-field-bg:#ffffff;

  --shil-border:#77d6ff;
  --shil-border-soft:#bfefff;

  --shil-shadow:
    0 2px 10px rgba(0,0,0,.05),
    0 0 0 1px rgba(119,214,255,.18);

  --shil-radius:18px;
}


/* کل صفحات مهندسی */
body:not(.login-page):not(.welcome-page) .shil-main{
  background:
    linear-gradient(
      180deg,
      #dce6eb 0%,
      #d7e2e7 100%
    ) !important;
}


/* کارت های اصلی */
.shil-section-card,
.shil-card,
.shil-result-card,
.shil-summary-card,
.shil-calculation-card{

  background:var(--shil-card-bg) !important;
  border:1px solid var(--shil-border) !important;
  border-radius:var(--shil-radius) !important;
  box-shadow:var(--shil-shadow) !important;
}


/* فیلدها */
input,
select,
textarea,
.shil-field,
.shil-input,
.shil-select{

  background:var(--shil-field-bg) !important;
  border:1px solid var(--shil-border-soft) !important;
  border-radius:14px !important;
}


/* هدر سکشن ها */
.shil-section-head{
  border-bottom:1px solid rgba(119,214,255,.35);
  padding-bottom:10px;
}


/* اطلاعات پروژه */
.shil-section-head.project-info{
  border-right:4px solid #2196f3;
}


/* شرایط محیطی */
.shil-section-head.environment{
  border-right:4px solid #00bcd4;
}


/* ورودی محاسبات */
.shil-section-head.inputs{
  border-right:4px solid #4caf50;
}


/* تنظیمات سیستم */
.shil-section-head.system{
  border-right:4px solid #ff9800;
}


/* خلاصه */
.shil-section-head.summary{
  border-right:4px solid #9c27b0;
}


/* اجرای محاسبات */
.shil-section-head.run{
  border-right:4px solid #ffc107;
}


/* فاصله استاندارد موبایل */
.shil-section-card{
  margin-bottom:12px !important;
}


/* نتایج */
.shil-result-card{
  background:
    linear-gradient(
      180deg,
      #edf5f9,
      #e7f0f4
    ) !important;
}