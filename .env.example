# SHIL client-side Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# production = secure RLS + Supabase Auth required
# development = temporary public-dev policies from supabase/schema.development.sql
VITE_SHIL_CLOUD_SECURITY_MODE=production

# Optional API/server layer
VITE_SHIL_API_BASE=
VITE_API_BASE_URL=

# Server-side only. Do NOT expose in Vite client code.
SHIL_ALLOWED_ORIGIN=*
SHIL_ADMIN_PIN=1366
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
SHIL_IMAGE_MODEL=gpt-image-1
