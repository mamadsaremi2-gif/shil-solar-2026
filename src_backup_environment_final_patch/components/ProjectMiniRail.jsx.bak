import React from "react";
import { useLocation } from "react-router-dom";
import IosIconGrid from "./IosIconGrid.jsx";
import { projectSteps } from "../data/shilFlowConfig.jsx";

function getActiveStepKey(pathname = "") {
  if (
    pathname === "/new-project" ||
    pathname === "/new-project/" ||
    pathname.startsWith("/new-project/path") ||
    pathname.startsWith("/new-project/execution") ||
    pathname.startsWith("/new-project/solar/select")
  ) {
    return "path";
  }

  if (pathname.startsWith("/new-project/info")) return "info";
  if (pathname.startsWith("/new-project/environment")) return "environment";
  if (
    pathname.startsWith("/new-project/method") ||
    pathname.startsWith("/new-project/solar/") ||
    pathname.startsWith("/new-project/emergency")
  ) {
    return "method";
  }

  if (
    pathname.startsWith("/new-project/input") ||
    pathname.startsWith("/new-project/inputs")
  ) {
    return "inputs";
  }

  if (pathname.startsWith("/new-project/system")) return "system";
  if (pathname.startsWith("/new-project/summary")) return "summary";
  if (pathname.startsWith("/new-project/run")) return "run";
  if (pathname.startsWith("/new-project/future")) return "future";

  return "path";
}

export default function ProjectMiniRail() {
  const { pathname } = useLocation();
  const activeKey = getActiveStepKey(pathname);

  const items = projectSteps.map((step) => ({
    ...step,
    active: step.key === activeKey,
  }));

  return (
    <div className="shil-project-mini-rail" aria-label="مسیر مراحل پروژه">
      <IosIconGrid items={items} gridClass="project-mini-rail-grid" />
    </div>
  );
}
