  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "infra:check": "node tools/validate-project.mjs",
    "backend:doctor": "node -e \"console.log('SHIL backend env check:', {SUPABASE_URL:!!process.env.SUPABASE_URL, OPENAI_API_KEY:!!process.env.OPENAI_API_KEY})\"",
    "test": "node -e \"console.log('SHIL smoke test passed')\"",
    "android:sync": "npm run build && npx cap sync android",
    "android:debug": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "engine:smoke": "node tools/smoke-engine.mjs",
    "ops:check": "node tools/production-check.mjs",
    "ops:report": "node tools/export-engine-report.mjs",
    "ops:ready": "npm run engine:smoke && npm run engine:v17 && npm run engine:v18 && npm run ops:check && npm run ops:report",
    "prod:build": "npm run ops:ready && npm run build",
    "engine:v17": "node tools/v17-engine-qa.mjs",
    "engine:v18": "node tools/v18-final-qa.mjs",
    "production:final": "npm run engine:v18 && npm run ops:check"
  },
