body.shil-project-info-screen,
body.shil-project-info-screen #root {
  width: 100%;
  height: 100dvh;
  overflow: hidden !important;
  overscroll-behavior: none;
  touch-action: manipulation;
}

body.shil-project-info-screen {
  position: fixed;
  inset: 0;
  max-width: 100vw;
}

/* هدر و فوتر شیشه‌ای */
body.shil-project-info-screen .shil-fixed-header,
body.shil-project-info-screen .shil-fixed-footer,
body.shil-project-info-screen header,
body.shil-project-info-screen footer {
  height: 40px !important;
  min-height: 40px !important;
  background: rgba(255,255,255,0.07) !important;
  backdrop-filter: blur(18px) saturate(1.35);
  -webkit-backdrop-filter: blur(18px) saturate(1.35);
  border: 1px solid rgba(255,255,255,0.13) !important;
  box-shadow: none !important;
}

/* کارت عنوان وسط هدر */
body.shil-project-info-screen .shil-fixed-header h1,
body.shil-project-info-screen .shil-fixed-header .shil-header-title,
body.shil-project-info-screen header h1 {
  font-weight: 900 !important;
  color: #eef7ff !important;
  background: linear-gradient(135deg, rgba(0,220,255,.36), rgba(160,80,255,.42)) !important;
  border: 1px solid rgba(100,230,255,.5) !important;
  box-shadow: 0 0 18px rgba(0,210,255,.24), 0 0 28px rgba(160,80,255,.2) !important;
  border-radius: 999px;
  padding: 8px 18px;
}

/* ریل مرحله‌ها دقیقاً چسبیده زیر هدر */
body.shil-project-info-screen .shil-engineering-rail,
body.shil-project-info-screen .shil-step-rail,
body.shil-project-info-screen .shil-flow-rail,
body.shil-project-info-screen .shil-project-rail {
  position: fixed !important;
  top: 56px !important;
  left: 10px !important;
  right: 10px !important;
  height: 56px !important;
  min-height: 56px !important;
  background: rgba(255,255,255,.08) !important;
  backdrop-filter: blur(18px) saturate(1.35);
  -webkit-backdrop-filter: blur(18px) saturate(1.35);
  border: 1px solid rgba(255,255,255,.14) !important;
  border-radius: 0 0 18px 18px !important;
  overflow-x: auto;
  overflow-y: hidden;
  z-index: 50;
}

/* محتوای صفحه بدون اسکرول */
body.shil-project-info-screen .shil-page-content,
body.shil-project-info-screen main {
  height: 100dvh !important;
  max-height: 100dvh !important;
  overflow: hidden !important;
  padding-top: 122px !important;
  padding-bottom: 62px !important;
}

/* کارت کلی صفحه */
body.shil-project-info-screen .shil-card-stack,
body.shil-project-info-screen .shil-section-stack,
body.shil-project-info-screen .shil-form-stack {
  height: calc(100dvh - 184px) !important;
  max-height: calc(100dvh - 184px) !important;
  overflow: hidden !important;
  padding: 8px 10px !important;
  display: grid !important;
  gap: 8px !important;
}

/* کارت‌های داخلی فشرده */
body.shil-project-info-screen .shil-section-card,
body.shil-project-info-screen .shil-panel,
body.shil-project-info-screen .shil-form-card {
  padding: 10px !important;
  border-radius: 18px !important;
  overflow: hidden !important;
  margin: 0 !important;
}

/* مشخصات اولیه پروژه به شکل ردیفی/جدولی */
body.shil-project-info-screen form,
body.shil-project-info-screen .shil-form-grid,
body.shil-project-info-screen .shil-project-info-grid,
body.shil-project-info-screen .shil-info-grid {
  display: grid !important;
  grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
  gap: 8px !important;
  align-items: stretch !important;
}

/* فیلدها کوچک و موبایل‌فرست */
body.shil-project-info-screen label,
body.shil-project-info-screen .shil-field,
body.shil-project-info-screen .shil-input-field {
  margin: 0 !important;
  min-height: 56px !important;
}

body.shil-project-info-screen input,
body.shil-project-info-screen textarea,
body.shil-project-info-screen select {
  min-height: 38px !important;
  height: 38px !important;
  padding: 6px 10px !important;
  font-size: clamp(11px, 3vw, 13px) !important;
  border-radius: 12px !important;
  text-align: center !important;
}

/* توضیحات پروژه فشرده */
body.shil-project-info-screen textarea {
  height: 82px !important;
  min-height: 82px !important;
  max-height: 82px !important;
  resize: none !important;
}

/* تیترها فشرده */
body.shil-project-info-screen h1,
body.shil-project-info-screen h2,
body.shil-project-info-screen h3,
body.shil-project-info-screen .shil-section-head {
  margin: 0 0 6px 0 !important;
  font-size: clamp(12px, 3.2vw, 15px) !important;
}

/* دکمه تأیید هم‌رنگ عنوان هدر */
body.shil-project-info-screen .shil-primary-wide,
body.shil-project-info-screen button[type="submit"],
body.shil-project-info-screen button {
  min-height: 46px !important;
  border-radius: 16px !important;
  color: #eef7ff !important;
  font-weight: 900 !important;
  background: linear-gradient(135deg, rgba(0,220,255,.46), rgba(160,80,255,.48)) !important;
  border: 1px solid rgba(100,230,255,.55) !important;
  box-shadow: 0 0 18px rgba(0,210,255,.22), 0 0 30px rgba(160,80,255,.18) !important;
}

/* موبایل */
@media (max-width: 680px) {
  body.shil-project-info-screen .shil-card-stack,
  body.shil-project-info-screen .shil-section-stack,
  body.shil-project-info-screen .shil-form-stack {
    gap: 6px !important;
    padding: 6px 8px !important;
  }

  body.shil-project-info-screen form,
  body.shil-project-info-screen .shil-form-grid,
  body.shil-project-info-screen .shil-project-info-grid,
  body.shil-project-info-screen .shil-info-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    gap: 6px !important;
  }

  body.shil-project-info-screen textarea {
    height: 72px !important;
    min-height: 72px !important;
    max-height: 72px !important;
  }
}

/* حذف فاصله بین هدر و ریل مرحله‌ها */
body.shil-project-info-screen .shil-engineering-rail,
body.shil-project-info-screen .shil-step-rail,
body.shil-project-info-screen .shil-flow-rail,
body.shil-project-info-screen .shil-project-rail {
  top: 56px !important;
  margin-top: 0 !important;
  transform: translateY(0) !important;
  border-top-left-radius: 0 !important;
  border-top-right-radius: 0 !important;
}

/* اطمینان از چسبیدن ریل به پایین هدر */
body.shil-project-info-screen .shil-fixed-header,
body.shil-project-info-screen header {
  bottom: auto !important;
  margin-bottom: 0 !important;
}

/* حذف پدینگ اضافه بالای محتوای صفحه */
body.shil-project-info-screen .shil-page-content,
body.shil-project-info-screen main {
  padding-top: 112px !important;
}


/* دکمه تایید همیشه بالای فوتر و کاملا قابل مشاهده */
body.shil-project-info-screen .shil-primary-wide,
body.shil-project-info-screen button[type="submit"] {
  position: fixed !important;
  left: 10px !important;
  right: 10px !important;
  bottom: 58px !important;
  z-index: 80 !important;
  min-height: 48px !important;
  max-height: 48px !important;
  margin: 0 !important;
}

/* محتوای صفحه به زیر دکمه تایید نرود */
body.shil-project-info-screen .shil-page-content,
body.shil-project-info-screen main {
  padding-bottom: 112px !important;
}

/* فوتر پایین صفحه ثابت بماند */
body.shil-project-info-screen .shil-fixed-footer,
body.shil-project-info-screen footer {
  position: fixed !important;
  left: 0 !important;
  right: 0 !important;
  bottom: 0 !important;
  height: 40px !important;
  z-index: 70 !important;
}


 /* FORCE HEADER 55PX */
.shil-fixed-header,
body .shil-fixed-header,
body[class*="shil-"] .shil-fixed-header {
  height: 55px !important;
  min-height: 55px !important;
  max-height: 55px !important;
  padding-top: 0 !important;
  padding-bottom: 0 !important;
  box-sizing: border-box !important;
}


/* ===== FORCE FOOTER 40PX ===== */

.shil-bottom-nav,
.shil-footer,
footer{
    height:40px !important;
    min-height:40px !important;
    max-height:40px !important;
    padding-top:0 !important;
    padding-bottom:0 !important;
    box-sizing:border-box !important;
}


/* ===== FORCE FIXED FOOTER 40PX ===== */

.shil-bottom-nav,
.shil-footer,
footer {
  position: fixed !important;
  left: 0 !important;
  right: 0 !important;
  bottom: 0 !important;
  width: 100% !important;
  height: 40px !important;
  min-height: 40px !important;
  max-height: 40px !important;
  padding-top: 0 !important;
  padding-bottom: 0 !important;
  box-sizing: border-box !important;
  z-index: 9999 !important;
}

/* محتوا زیر فوتر گیر نکند */
body,
#root,
.shil-page,
.shil-page-shell,
.shil-main,
main {
  padding-bottom: 40px !important;
  box-sizing: border-box !important;
}

/* اگر خود صفحه اسکرول دارد */
.shil-page-content,
.shil-content,
.page-content,
main {
  padding-bottom: 56px !important;
  box-sizing: border-box !important;
}


/* ===== FORCE TRUE FIXED BOTTOM NAV - MOBILE FIRST ===== */

html,
body,
#root {
  min-height: 100% !important;
  height: 100% !important;
}

.shil-bottom-nav,
.shil-footer,
footer,
[class*="bottom-nav"],
[class*="BottomNav"],
[class*="footer"],
[class*="Footer"] {
  position: fixed !important;
  inset-inline-start: 0 !important;
  inset-inline-end: 0 !important;
  left: 0 !important;
  right: 0 !important;
  bottom: 0 !important;
  width: 100vw !important;
  height: 40px !important;
  min-height: 40px !important;
  max-height: 40px !important;
  padding-top: 0 !important;
  padding-bottom: 0 !important;
  margin-bottom: 0 !important;
  box-sizing: border-box !important;
  z-index: 2147483647 !important;
  transform: none !important;
}

/* اگر فوتر داخل main یا container اسکرولی باشد، محتوا زیرش رد شود */
main,
.shil-main,
.shil-page,
.shil-page-shell,
.shil-page-content,
.shil-content,
.mobile-first-page,
.mobile-page,
[class*="mobile-first"],
[class*="MobileFirst"],
[class*="page-content"],
[class*="PageContent"] {
  padding-bottom: 56px !important;
  box-sizing: border-box !important;
  overflow-x: hidden !important;
}

/* جلوگیری از اینکه parent با transform باعث fixed اشتباه شود */
.shil-page,
.shil-page-shell,
.mobile-first-page,
.mobile-page,
[class*="mobile-first"],
[class*="MobileFirst"] {
  transform: none !important;
  perspective: none !important;
  filter: none !important;
  contain: none !important;
}


/* ===== FINAL FIX: SHIL PAGE SHELL HEADER FOOTER ===== */

.shil-page-shell {
  min-height: 100dvh !important;
  height: 100dvh !important;
  overflow: hidden !important;
  position: relative !important;
}

.shil-fixed-header {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  right: 0 !important;
  height: 55px !important;
  min-height: 55px !important;
  max-height: 55px !important;
  box-sizing: border-box !important;
  z-index: 9999 !important;
}

.shil-fixed-footer,
.shil-bottom-nav,
.shil-footer,
footer {
  position: fixed !important;
  left: 0 !important;
  right: 0 !important;
  bottom: 0 !important;
  width: 100% !important;
  height: 40px !important;
  min-height: 40px !important;
  max-height: 40px !important;
  padding-top: 0 !important;
  padding-bottom: 0 !important;
  box-sizing: border-box !important;
  z-index: 9999 !important;
}

.shil-page-content {
  position: fixed !important;
  top: 55px !important;
  bottom: 40px !important;
  left: 0 !important;
  right: 0 !important;
  height: auto !important;
  min-height: 0 !important;
  max-height: none !important;
  overflow-y: auto !important;
  overflow-x: hidden !important;
  padding-bottom: 24px !important;
  box-sizing: border-box !important;
  -webkit-overflow-scrolling: touch !important;
}


/* =====================================================
   SHIL PAGE SHELL - FINAL LAYOUT
   ===================================================== */

.shil-page-shell{
    position:relative !important;
    width:100% !important;
    height:100dvh !important;
    min-height:100dvh !important;
    overflow:hidden !important;
}

.shil-page-content{
    position:absolute !important;

    top:55px !important;
    left:0 !important;
    right:0 !important;
    bottom:40px !important;

    overflow-y:auto !important;
    overflow-x:hidden !important;

    box-sizing:border-box !important;

    -webkit-overflow-scrolling:touch !important;
}

.shil-no-header .shil-page-content{
    top:0 !important;
}

.shil-no-footer .shil-page-content{
    bottom:0 !important;
}

.shil-fixed-header{
    position:fixed !important;
    top:0 !important;
    left:0 !important;
    right:0 !important;
    height:55px !important;
    min-height:55px !important;
    max-height:55px !important;
    z-index:4000 !important;
}

.shil-fixed-footer{
    position:fixed !important;
    left:0 !important;
    right:0 !important;
    bottom:0 !important;

    height:40px !important;
    min-height:40px !important;
    max-height:40px !important;

    z-index:4000 !important;
}

