/* SHIL orientation upload engineering frame update */
.shil-smart-upload-box{
  align-items:stretch;
}

.shil-orientation-frame{
  position:relative;
  width:100%;
  min-height:310px;
  margin-top:6px;
  padding:46px 46px 50px;
  border-radius:24px;
  border:1px dashed rgba(255,255,255,.30);
  background:linear-gradient(180deg,rgba(10,16,31,.78),rgba(4,9,22,.82));
  box-shadow:inset 0 0 0 1px rgba(60,180,255,.10), 0 18px 40px rgba(0,0,0,.25);
  overflow:hidden;
}

.shil-orientation-frame::before,
.shil-orientation-frame::after{
  content:"";
  position:absolute;
  pointer-events:none;
  opacity:.45;
}

.shil-orientation-frame::before{
  left:50%;
  top:18px;
  bottom:18px;
  width:1px;
  background:linear-gradient(to bottom,transparent,rgba(255,255,255,.45),transparent);
}

.shil-orientation-frame::after{
  top:50%;
  left:18px;
  right:18px;
  height:1px;
  background:linear-gradient(to right,transparent,rgba(255,255,255,.45),transparent);
}

.shil-orientation-image-shell{
  position:relative;
  z-index:1;
  width:100%;
  height:220px;
  border-radius:20px;
  border:1px solid rgba(255,255,255,.18);
  background:rgba(0,0,0,.42);
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:hidden;
}

.shil-upload-box .shil-orientation-image-shell img{
  width:100%;
  height:100%;
  max-height:none;
  object-fit:contain;
  border:0;
  border-radius:0;
  background:rgba(0,0,0,.24);
}

.shil-orientation-label{
  position:absolute;
  z-index:2;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:2px;
  min-width:82px;
  padding:7px 9px;
  border-radius:14px;
