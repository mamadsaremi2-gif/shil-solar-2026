  font-size:12px;
  font-weight:900;
  text-align:center;
  background:rgba(15,23,42,.82);
  border:1px solid rgba(96,165,250,.34);
  box-shadow:0 0 18px rgba(56,189,248,.12);
}

.shil-orientation-label small{
  color:rgba(255,255,255,.68);
  font-size:9px;
  line-height:1.4;
}

.shil-orientation-north{top:8px;left:50%;transform:translateX(-50%);}
.shil-orientation-south{bottom:8px;left:50%;transform:translateX(-50%);}
.shil-orientation-east{right:8px;top:50%;transform:translateY(-50%);}
.shil-orientation-west{left:8px;top:50%;transform:translateY(-50%);}

