.shil-main,
main {
  padding-bottom: 40px !important;
  box-sizing: border-box !important;
}

/* اگر خود صفحه اسکرول دارد */
.shil-page-content,
.shil-content,
.page-content,
main {
  padding-bottom: 56px !important;
  box-sizing: border-box !important;
}


/* اگر فوتر داخل main یا container اسکرولی باشد، محتوا زیرش رد شود */
main,
.shil-main,
.shil-page,
.shil-page-shell,
.shil-page-content,
.shil-content,
.mobile-first-page,
.mobile-page,
[class*="mobile-first"],
[class*="MobileFirst"],
[class*="page-content"],
[class*="PageContent"] {
  padding-bottom: 56px !important;
  box-sizing: border-box !important;
  overflow-x: hidden !important;
}

/* جلوگیری از اینکه parent با transform باعث fixed اشتباه شود */
.shil-page,
.shil-page-shell,
.mobile-first-page,
.mobile-page,
[class*="mobile-first"],
[class*="MobileFirst"] {
  transform: none !important;
  perspective: none !important;
  filter: none !important;
  contain: none !important;
}

/* =========================================================
   SHIL CLEAN FINAL LAYOUT
   Header: 55px | Footer: 40px | Main scroll area | Rail attached
   ========================================================= */

:root{
  --shil-header-h:55px;
  --shil-footer-h:40px;
  --shil-page-pad:16px;
  --shil-safe-x:16px;
}

html,
body,
#root{
  width:100%;
  min-height:100%;
  margin:0;
  overflow-x:hidden !important;
}

body:not(.login-page):not(.welcome-page){
  height:100dvh !important;
  overflow:hidden !important;
}

.shil-page-shell{
  position:relative !important;
  width:100% !important;
  height:100dvh !important;
  min-height:100dvh !important;
  overflow:hidden !important;
}

.shil-master-bg{
  position:fixed !important;
  inset:0 !important;
  z-index:0 !important;
  pointer-events:none !important;
}

.shil-fixed-header{
  position:fixed !important;
  top:0 !important;
  left:0 !important;
  right:0 !important;

  height:55px !important;
  min-height:55px !important;
  max-height:55px !important;

  padding-top:0 !important;
  padding-bottom:0 !important;
  box-sizing:border-box !important;

  display:flex !important;
  align-items:center !important;
  justify-content:space-between !important;

  z-index:5000 !important;
}

.shil-fixed-footer{
  position:fixed !important;
  left:0 !important;
  right:0 !important;
  bottom:0 !important;

  height:40px !important;
  min-height:40px !important;
  max-height:40px !important;

  padding-top:0 !important;
  padding-bottom:0 !important;
  box-sizing:border-box !important;

  display:flex !important;
  align-items:center !important;
  justify-content:space-around !important;

  z-index:5000 !important;
}

.shil-fixed-footer a{
  height:32px !important;
  min-height:32px !important;
  display:flex !important;
  align-items:center !important;
  justify-content:center !important;
  box-sizing:border-box !important;
}

.shil-page-content,
main.shil-page-content{
  position:fixed !important;

  top:55px !important;
  left:0 !important;
  right:0 !important;
  bottom:40px !important;

  width:auto !important;
  height:auto !important;
  min-height:0 !important;
  max-height:none !important;

  padding:0 !important;
  margin:0 !important;

  overflow-y:auto !important;
  overflow-x:hidden !important;

  box-sizing:border-box !important;
  -webkit-overflow-scrolling:touch !important;
  scrollbar-width:thin !important;
}

.shil-no-header .shil-page-content{
  top:0 !important;
}

.shil-no-footer .shil-page-content{
  bottom:0 !important;
}

/* Project mini rail: first child of main, so it attaches under header */
.shil-project-mini-rail{
  position:sticky !important;
  top:0 !important;
  z-index:3000 !important;

  width:100% !important;
  max-width:100% !important;

  margin:0 !important;
  padding:10px 8px !important;

  box-sizing:border-box !important;

  overflow-x:auto !important;
  overflow-y:hidden !important;
}

.project-mini-rail-grid{
  display:flex !important;
  grid-template-columns:none !important;
  flex-wrap:nowrap !important;
  width:max-content !important;
  max-width:none !important;
  min-width:100% !important;
}

.shil-engineering-content{
  width:100% !important;
  max-width:100% !important;
  padding:14px 14px 24px !important;
  margin:0 !important;
  box-sizing:border-box !important;
}

.shil-engineering-content > *:first-child{
  margin-top:0 !important;
}

/* Page-specific old padding reset */
body.shil-project-path-screen .shil-page-content,
body.shil-project-path-screen main.shil-page-content,
body.shil-calculation-method-screen .shil-page-content,
body.shil-calculation-method-screen main.shil-page-content,
body.shil-calculation-inputs-screen .shil-page-content,
body.shil-calculation-inputs-screen main.shil-page-content{
  padding-top:0 !important;
  padding-bottom:0 !important;
  overflow-y:auto !important;
}

/* Old ShilFrame compatibility */
.shil-frame{
  width:100% !important;
  height:100dvh !important;
  position:relative !important;
  overflow:hidden !important;
}

.shil-frame-main{
  position:absolute !important;
  top:55px !important;
  left:0 !important;
  right:0 !important;
  bottom:40px !important;
  height:auto !important;
  padding:0 !important;
  overflow-y:auto !important;
  overflow-x:hidden !important;
  box-sizing:border-box !important;
}

.shil-header{
  position:fixed !important;
  top:0 !important;
  left:0 !important;
  right:0 !important;
  height:55px !important;
  min-height:55px !important;
  max-height:55px !important;
  z-index:5000 !important;
}

.shil-footer{
  position:fixed !important;
  left:0 !important;
  right:0 !important;
  bottom:0 !important;
  height:40px !important;
  min-height:40px !important;
  max-height:40px !important;
  z-index:5000 !important;
}

@media (max-width:430px){
  :root{
    --shil-header-h:55px;
    --shil-footer-h:40px;
    --shil-page-pad:14px;
    --shil-safe-x:14px;
  }

  .shil-fixed-header{
    height:55px !important;
    min-height:55px !important;
    max-height:55px !important;
  }

  .shil-fixed-footer{
    height:40px !important;
    min-height:40px !important;
    max-height:40px !important;
  }
}


