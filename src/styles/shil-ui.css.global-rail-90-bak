* {
  font-family: Vazirmatn, Tahoma, Arial, sans-serif;
}
*{
  box-sizing:border-box;
}

html,
body,
#root{
  margin:0;
  min-height:100%;
  background:#030712;
  font-family:Tahoma, Arial, sans-serif;
}

body{
  overflow-x:hidden;
}

a{
  text-decoration:none;
  color:inherit;
}

button,
input,
select,
textarea{
  font-family:inherit;
}

/* =========================
   DASHBOARD SHELL
========================= */

.dashboard-shell-v15{
  width:100%;
  max-width:430px;
  min-height:100vh;
  margin:0 auto;
  position:relative;
  overflow-x:hidden;

  color:#fff;

  background:
    radial-gradient(
      circle at 50% -10%,
      rgba(98,0,255,.42),
      transparent 34%
    ),

    radial-gradient(
      circle at 0% 22%,
      rgba(0,229,255,.18),
      transparent 30%
    ),

    linear-gradient(
      180deg,
      #080d23 0%,
      #020613 100%
    );
}

/* =========================
   BG GLOW
========================= */

.dashboard-bg-glow{
  position:fixed;
  pointer-events:none;
  filter:blur(42px);
  opacity:.55;
  z-index:0;
}

.glow-1{
  width:170px;
  height:170px;
  top:74px;
  right:-70px;
  background:#00e5ff;
}

.glow-2{
  width:180px;
  height:180px;
  top:340px;
  left:-90px;
  background:#7c3cff;
}

.glow-3{
  width:140px;
  height:140px;
  bottom:80px;
  right:40px;
  background:#ff2bd6;
}

/* =========================
   HEADER
========================= */

.dashboard-header-v15{
  position:sticky;
  top:0;
  z-index:20;

  height:96px;

  padding:14px 16px;

  display:flex;
  align-items:center;
  justify-content:space-between;

  background:
    linear-gradient(
      135deg,
      rgba(15,23,42,.86),
      rgba(66,24,126,.78)
    );

  border-bottom:
    1px solid rgba(125,249,255,.18);

  backdrop-filter:blur(14px);
}

.header-icon-btn{
  width:48px;
  height:48px;

  border:1px solid rgba(125,249,255,.28);

  border-radius:18px;

  background:rgba(255,255,255,.055);

  color:#ecfeff;

  display:grid;
  place-items:center;

  box-shadow:
    inset 0 1px 10px rgba(255,255,255,.06),
    0 0 18px rgba(0,229,255,.08);
}

.header-btn-v15{
  width:48px;
  height:48px;

  border-radius:18px;

  display:grid;
  place-items:center;

  color:white;

  border:1px solid rgba(125,249,255,.24);

  background:
    rgba(255,255,255,.05);

  box-shadow:
    inset 0 1px 10px rgba(255,255,255,.05),
    0 0 18px rgba(0,229,255,.08);
}

/* =========================
   BRAND
========================= */

.header-brand-v15,
.brand-v15,
.project-brand-v15{
  text-align:center;
  line-height:1;
}

.header-brand-v15 h1,
.brand-v15 h1,
.project-brand-v15 h1{
  margin:0;
  font-size:34px;
  font-weight:900;
  letter-spacing:4px;

  text-shadow:
    0 0 16px rgba(0,229,255,.38),
    0 0 28px rgba(168,85,247,.28);
}

.header-brand-v15 span,
.brand-v15 span,
.project-brand-v15 span{
  display:block;

  margin-top:8px;

  font-size:10px;

  letter-spacing:1.4px;

  color:#b9f6ff;
}

/* =========================
   MAIN
========================= */

.dashboard-main-v15{
  position:relative;
  z-index:2;

  padding:16px 14px 180px;
}

/* =========================
   HERO
========================= */

.hero-v15,
.hero-card-v15{
  position:relative;

  overflow:hidden;

  border-radius:32px;

  padding:20px;

  margin-bottom:16px;

  border:
    1px solid rgba(125,249,255,.22);

  background:
    radial-gradient(
      circle at top right,
      rgba(0,229,255,.18),
      transparent 34%
    ),

    radial-gradient(
      circle at bottom left,
      rgba(124,58,237,.22),
      transparent 42%
    ),

    linear-gradient(
      145deg,
      rgba(9,24,48,.92),
      rgba(3,7,18,.96)
    );

  box-shadow:
    0 18px 46px rgba(0,0,0,.36),
    inset 0 1px 18px rgba(255,255,255,.04);
}

.hero-topline,
.hero-row-v15{
  display:flex;
  justify-content:space-between;

  margin-bottom:18px;

  color:#9cf6ff;

  font-size:11px;
}

.hero-logo-wrap{
  position:relative;
  text-align:center;
  margin-bottom:18px;
}

.hero-logo-glow{
  position:absolute;
  inset:-16px 40px;

  border-radius:999px;

  background:
    radial-gradient(
      circle,
      rgba(168,85,247,.42),
      transparent 68%
    );

  filter:blur(16px);
}

.hero-logo-wrap h1{
  position:relative;

  margin:0;

  font-size:58px;

  font-weight:900;

  letter-spacing:8px;
}

.hero-logo-wrap p{
  margin:8px 0 0;

  font-size:11px;

  letter-spacing:1.6px;

  color:#d8b4fe;
}

.hero-content h2,
.hero-content-v15 h1{
  margin:0 0 10px;

  font-size:28px;

  line-height:1.7;

  font-weight:900;
}

.hero-content p,
.hero-content-v15 h2{
  margin:0;

  font-size:14px;

  line-height:2;

  color:#cbd5e1;
}

/* =========================
   DASH PANEL
========================= */

.dash-panel-v15{
  border-radius:28px;

  padding:14px;

  margin-bottom:16px;

  border:
    1px solid rgba(125,249,255,.2);

  background:
    rgba(15,23,42,.58);

  backdrop-filter:blur(12px);
}

.dash-section-head{
  display:flex;
  align-items:center;
  justify-content:space-between;

  margin-bottom:12px;
}

.dash-section-head h2{
  margin:0;

  font-size:20px;

  font-weight:900;
}

.dash-grid-v15{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
}

/* =========================
   DASH CARD
========================= */

.dash-card-v15{
  position:relative;

  overflow:hidden;

  min-height:136px;

  border-radius:24px;

  padding:12px 10px;

  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;

  gap:7px;

  text-align:center;

  border:
    1px solid rgba(125,249,255,.18);

  background:
    radial-gradient(
      circle at 50% 0%,
      rgba(255,255,255,.08),
      transparent 36%
    ),

    linear-gradient(
      145deg,
      rgba(17,31,58,.92),
      rgba(5,10,26,.96)
    );

  box-shadow:
    0 14px 30px rgba(0,0,0,.28),
    inset 0 1px 12px rgba(255,255,255,.045);
}

.dash-card-menu{
  position:absolute;
  top:9px;
  left:11px;

  font-size:14px;

  color:rgba(255,255,255,.38);
}

.dash-icon-v15,
.step-icon-v15{
  width:58px;
  height:58px;

  border-radius:20px;

  display:grid;
  place-items:center;

  color:white;

  border:
    1px solid rgba(255,255,255,.16);

  box-shadow:
    inset 0 1px 10px rgba(255,255,255,.08),
    0 0 18px rgba(0,229,255,.12);
}

.dash-card-v15 h3{
  margin:2px 0 0;

  font-size:14px;

  font-weight:900;
}

.dash-card-v15 p{
  margin:0;

  font-size:11px;

  line-height:1.45;

  color:#b8c7d9;
}

.dash-card-dot{
  position:absolute;
  right:12px;
  bottom:11px;

  width:7px;
  height:7px;

  border-radius:999px;

  background:#67e8f9;
}

/* =========================
   TONES
========================= */

.cyan .dash-icon-v15,
.cyan .step-icon-v15{
  background:
    linear-gradient(
      145deg,
      #0e7490,
      #1e3a8a
    );
}

.blue .dash-icon-v15,
.blue .step-icon-v15{
  background:
    linear-gradient(
      145deg,
      #0284c7,
      #312e81
    );
}

.amber .dash-icon-v15,
.amber .step-icon-v15{
  background:
    linear-gradient(
      145deg,
      #f59e0b,
      #7c2d12
    );
}

.purple .dash-icon-v15,
.purple .step-icon-v15{
  background:
    linear-gradient(
      145deg,
      #7c3aed,
      #0e7490
    );
}

.pink .dash-icon-v15,
.pink .step-icon-v15{
  background:
    linear-gradient(
      145deg,
      #db2777,
      #4c1d95
    );
}

.violet .dash-icon-v15,
.violet .step-icon-v15{
  background:
    linear-gradient(
      145deg,
      #a855f7,
      #2563eb
    );
}

.green .step-icon-v15{
  background:
    linear-gradient(
      145deg,
      #22c55e,
      #14532d
    );
}

.yellow .step-icon-v15{
  background:
    linear-gradient(
      145deg,
      #eab308,
      #713f12
    );
}

.silver .step-icon-v15{
  background:
    linear-gradient(
      145deg,
      #94a3b8,
      #1e293b
    );
}

/* =========================
   STATUS CARD
========================= */

.status-card-v15{
  border-radius:28px;

  padding:18px;

  margin-bottom:16px;

  border:
    1px solid rgba(125,249,255,.2);

  background:
    linear-gradient(
      145deg,
      rgba(10,22,44,.86),
      rgba(4,8,20,.94)
    );
}

.status-chip{
  width:fit-content;

  padding:7px 12px;

  border-radius:999px;

  margin-bottom:12px;

  font-size:11px;

  font-weight:900;

  color:#001018;

  background:#67e8f9;
}

.status-card-v15 h2{
  margin:0 0 10px;

  font-size:21px;

  font-weight:900;
}

.status-card-v15 p{
  margin:0;

  font-size:13px;

  line-height:1.9;

  color:#cbd5e1;
}

/* =========================
   NEW PROJECT
========================= */

.project-shell-v15{
  width:100%;
  max-width:430px;
  min-height:100vh;
  margin:0 auto;
  position:relative;
  overflow-x:hidden;
  color:#fff;
}

.project-header-v15{
  position:sticky;
  top:0;
  z-index:20;

  height:96px;

  padding:14px;

  display:flex;
  align-items:center;
  justify-content:space-between;

  background:
    linear-gradient(
      135deg,
      rgba(15,23,42,.88),
      rgba(66,24,126,.78)
    );

  border-bottom:
    1px solid rgba(125,249,255,.18);

  backdrop-filter:blur(14px);
}

.project-header-btn{
  min-width:86px;
  height:46px;

  padding:0 12px;

  border-radius:18px;

  display:grid;
  place-items:center;

  font-size:13px;
  font-weight:900;

  color:#ecfeff;

  border:
    1px solid rgba(125,249,255,.28);

  background:
    rgba(255,255,255,.055);
}

.project-header-btn.primary{
  background:
    linear-gradient(
      145deg,
      rgba(168,85,247,.36),
      rgba(14,165,233,.28)
    );
}

.project-main-v15{
  position:relative;
  z-index:2;

  padding:18px 14px 120px;
}

.project-title-v15{
  text-align:center;

  margin-bottom:16px;

  padding:18px 12px;

  border-radius:28px;

  border:
    1px solid rgba(125,249,255,.22);

  background:
    linear-gradient(
      145deg,
      rgba(9,24,48,.88),
      rgba(3,7,18,.96)
    );
}

.project-title-v15 h2{
  margin:0 0 8px;

  font-size:28px;

  font-weight:900;
}

.project-title-v15 p{
  margin:0;

  color:#cbd5e1;

  font-size:13px;
}

.project-step-grid-v15{
  display:grid;
  grid-template-columns:1fr;
  gap:12px;
}

.project-step-card-v15{
  position:relative;

  min-height:142px;

  overflow:hidden;

  border-radius:26px;

  padding:16px;

  display:grid;

  grid-template-columns:74px 1fr;

  gap:14px;

  align-items:center;

  border:
    1px solid rgba(125,249,255,.2);

  background:
    linear-gradient(
      145deg,
      rgba(17,31,58,.92),
      rgba(5,10,26,.96)
    );
}

.step-number-v15{
  position:absolute;
  top:14px;
  left:14px;

  width:34px;
  height:34px;

  border-radius:12px;

  display:grid;
  place-items:center;

  font-size:18px;
  font-weight:900;

  color:#dffbff;

  border:
    1px solid rgba(125,249,255,.28);

  background:
    rgba(255,255,255,.055);
}

.project-step-card-v15 h3{
  margin:0 0 6px;

  font-size:20px;

  font-weight:900;
}

.project-step-card-v15 p{
  margin:0;

  font-size:12px;

  line-height:1.55;

  color:#b8c7d9;
}

/* =========================
   PROJECT FORM
========================= */

.project-field-v15{
  margin-top:18px;
}

.project-field-v15 label{
  display:block;

  margin-bottom:10px;

  font-size:13px;

  color:#b9f6ff;

  font-weight:700;
}

.project-field-v15 input,
.project-field-v15 select,
.project-field-v15 textarea{
  width:100%;

  border:none;
  outline:none;

  border-radius:18px;

  padding:16px;

  color:white;

  font-size:14px;

  background:
    rgba(255,255,255,.05);

  border:
    1px solid rgba(125,249,255,.14);

  box-shadow:
    inset 0 1px 8px rgba(255,255,255,.04);
}

.project-field-v15 textarea{
  resize:none;
}

.project-field-v15 input::placeholder,
.project-field-v15 textarea::placeholder{
  color:#94a3b8;
}

/* =========================
   ACTION BAR
========================= */

.project-actionbar-v15{
  position:fixed;

  left:50%;
  bottom:86px;

  transform:translateX(-50%);

  width:calc(100% - 24px);

  max-width:406px;

  display:grid;

  grid-template-columns:
    1fr 1fr 1fr;

  gap:10px;

  z-index:25;
}

.action-btn-v15{
  height:56px;

  border:none;

  border-radius:22px;

  display:flex;

  align-items:center;
  justify-content:center;

  gap:8px;

  color:white;

  font-size:12px;

  font-weight:800;

  background:
    linear-gradient(
      145deg,
      rgba(17,31,58,.92),
      rgba(5,10,26,.96)
    );

  border:
    1px solid rgba(125,249,255,.18);
}

.action-btn-v15.primary{
  background:
    linear-gradient(
      145deg,
      rgba(168,85,247,.42),
      rgba(14,165,233,.32)
    );
}

.action-btn-v15.secondary{
  background:
    linear-gradient(
      145deg,
      rgba(8,145,178,.38),
      rgba(30,64,175,.32)
    );
}

/* =========================
   BOTTOM NAV
========================= */

.bottom-nav-v15{
  position:fixed;

  z-index:30;

  left:50%;
  bottom:12px;

  transform:translateX(-50%);

  width:calc(100% - 24px);

  max-width:406px;

  display:grid;

  grid-template-columns:1fr 1fr 1fr;

  gap:10px;

  padding:10px;

  border-radius:28px;

  border:
    1px solid rgba(125,249,255,.2);

  background:
    rgba(5,10,24,.88);

  backdrop-filter:blur(16px);
}

.bottom-nav-item{
  height:58px;

  border-radius:22px;

  display:grid;
  place-items:center;

  gap:2px;

  color:#cbd5e1;

  background:
    rgba(255,255,255,.04);
}

.bottom-nav-item.active{
  color:white;

  background:
    linear-gradient(
      145deg,
      rgba(14,165,233,.34),
      rgba(124,58,237,.36)
    );
}

.bottom-nav-item span{
  font-size:10px;
  font-weight:800;
}
/* =========================
   ENVIRONMENT PAGE
========================= */

.environment-map-v15{
  position:relative;

  height:220px;

  overflow:hidden;

  border-radius:24px;

  margin-top:12px;

  background:
    linear-gradient(
      145deg,
      rgba(8,20,40,.95),
      rgba(4,8,20,.96)
    );

  border:
    1px solid rgba(125,249,255,.14);
}

.map-grid-v15{
  position:absolute;
  inset:0;

  background-image:
    linear-gradient(
      rgba(255,255,255,.04) 1px,
      transparent 1px
    ),

    linear-gradient(
      90deg,
      rgba(255,255,255,.04) 1px,
      transparent 1px
    );

  background-size:24px 24px;
}

.map-center-dot{
  position:absolute;

  top:50%;
  left:50%;

  transform:translate(-50%,-50%);

  width:18px;
  height:18px;

  border-radius:999px;

  background:#67e8f9;

  box-shadow:
    0 0 20px rgba(103,232,249,.95),
    0 0 40px rgba(103,232,249,.55);
}

.map-overlay-v15{
  position:absolute;

  left:14px;
  bottom:14px;

  padding:10px 14px;

  border-radius:16px;

  font-size:12px;
  font-weight:800;

  color:white;

  background:
    rgba(0,0,0,.34);

  backdrop-filter:blur(12px);

  border:
    1px solid rgba(125,249,255,.18);
}

/* ENV GRID */

.environment-grid-v15{
  display:grid;

  grid-template-columns:1fr 1fr;

  gap:12px;

  margin-top:16px;
}

.environment-card-v15{
  min-height:150px;

  position:relative;

  overflow:hidden;

  border-radius:24px;

  padding:16px 12px;

  display:flex;

  flex-direction:column;

  align-items:center;
  justify-content:center;

  text-align:center;

  border:
    1px solid rgba(125,249,255,.18);

  background:
    linear-gradient(
      145deg,
      rgba(17,31,58,.92),
      rgba(5,10,26,.96)
    );

  box-shadow:
    0 14px 30px rgba(0,0,0,.24),
    inset 0 1px 10px rgba(255,255,255,.04);
}

.environment-icon-v15{
  width:62px;
  height:62px;

  border-radius:22px;

  display:grid;
  place-items:center;

  margin-bottom:14px;

  color:white;

  border:
    1px solid rgba(255,255,255,.14);

  box-shadow:
    inset 0 1px 10px rgba(255,255,255,.06),
    0 0 18px rgba(0,229,255,.08);
}

.environment-card-v15 h3{
  margin:0 0 8px;

  font-size:14px;

  line-height:1.7;

  font-weight:900;
}

.environment-card-v15 p{
  margin:0;

  font-size:11px;

  line-height:1.7;

  color:#b8c7d9;
}

.environment-card-v15.cyan .environment-icon-v15{
  background:
    linear-gradient(
      145deg,
      #0e7490,
      #1e3a8a
    );
}

.environment-card-v15.blue .environment-icon-v15{
  background:
    linear-gradient(
      145deg,
      #0284c7,
      #312e81
    );
}

.environment-card-v15.amber .environment-icon-v15{
  background:
    linear-gradient(
      145deg,
      #f59e0b,
      #7c2d12
    );
}

.environment-card-v15.purple .environment-icon-v15{
  background:
    linear-gradient(
      145deg,
      #7c3aed,
      #0e7490
    );
}

.environment-card-v15.green .environment-icon-v15{
  background:
    linear-gradient(
      145deg,
      #22c55e,
      #14532d
    );
}

.environment-card-v15.pink .environment-icon-v15{
  background:
    linear-gradient(
      145deg,
      #db2777,
      #4c1d95
    );
}

/* =========================
   ADVANCED DASHBOARD GRID
========================= */

.dashboard-grid-v15{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:14px;
  margin-top:18px;
}

.dash-card-v15{
  position:relative;

  min-height:190px;

  overflow:hidden;

  border-radius:28px;

  padding:16px 14px;

  display:flex;

  flex-direction:column;

  align-items:center;
  justify-content:center;

  text-align:center;

  border:
    1px solid rgba(125,249,255,.16);

  background:
    radial-gradient(
      circle at top,
      rgba(255,255,255,.08),
      transparent 34%
    ),

    linear-gradient(
      145deg,
      rgba(14,22,42,.95),
      rgba(4,8,20,.98)
    );

  box-shadow:
    0 18px 40px rgba(0,0,0,.28),
    inset 0 1px 10px rgba(255,255,255,.04);

  transition:
    transform .22s ease,
    border .22s ease,
    box-shadow .22s ease;
}

.dash-card-v15:hover{
  transform:translateY(-4px);

  border:
    1px solid rgba(103,232,249,.34);

  box-shadow:
    0 20px 44px rgba(0,0,0,.34),
    0 0 24px rgba(0,229,255,.10);
}

.dash-card-top-v15{
  position:absolute;

  top:10px;
  left:12px;
}

.dash-mini-dots{
  display:flex;
  gap:4px;
}

.dash-mini-dots span{
  width:5px;
  height:5px;

  border-radius:999px;

  background:
    rgba(255,255,255,.34);
}

.dash-icon-v15{
  width:72px;
