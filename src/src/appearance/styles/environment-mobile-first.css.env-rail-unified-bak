  padding-top: 0 !important;
  padding-bottom: 0 !important;
  margin-bottom: 0 !important;
  box-sizing: border-box !important;
  z-index: 2147483647 !important;
  transform: none !important;
}

/* اگر فوتر داخل main یا container اسکرولی باشد، محتوا زیرش رد شود */
main,
.shil-main,
.shil-page,
.shil-page-shell,
.shil-page-content,
.shil-content,
.mobile-first-page,
.mobile-page,
[class*="mobile-first"],
[class*="MobileFirst"],
[class*="page-content"],
[class*="PageContent"] {
  padding-bottom: 56px !important;
  box-sizing: border-box !important;
  overflow-x: hidden !important;
}

/* جلوگیری از اینکه parent با transform باعث fixed اشتباه شود */
.shil-page,
.shil-page-shell,
.mobile-first-page,
.mobile-page,
[class*="mobile-first"],
[class*="MobileFirst"] {
  transform: none !important;
  perspective: none !important;
  filter: none !important;
  contain: none !important;
}


