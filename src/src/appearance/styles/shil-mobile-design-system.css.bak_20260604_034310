/* ===== SOURCE: src/appearance/styles/shil-global-background-except-auth.css ===== */

/* =========================================================
   SHIL - GLOBAL PAGE BACKGROUND FIX
   Applies public background correctly in Vite:
   public/foo.webp  =>  url('/foo.webp')
   Excludes Login and Welcome pages.
   ========================================================= */

:root {
  --shil-main-bg-image: none;
  --shil-main-bg-overlay:
    radial-gradient(circle at 18% 8%, rgba(199,125,255,.22), transparent 34%),
    radial-gradient(circle at 88% 22%, rgba(80,220,196,.16), transparent 32%),
    linear-gradient(180deg, rgba(244,247,252,.92), rgba(226,232,242,.94));
}

/* Base app background */
html,
body,
#root {
  min-height: 100%;
}

/* All internal pages except Login / Welcome */
body:not(.login-page):not(.welcome-page) #root,
body:not(.login-page):not(.welcome-page) .app,
body:not(.login-page):not(.welcome-page) .shil-app,
body:not(.login-page):not(.welcome-page) .mobile-app,
body:not(.login-page):not(.welcome-page) .app-shell,
body:not(.login-page):not(.welcome-page) .shil-shell,
body:not(.login-page):not(.welcome-page) .mobile-shell,
body:not(.login-page):not(.welcome-page) .page,
body:not(.login-page):not(.welcome-page) .screen,
body:not(.login-page):not(.welcome-page) .mobile-page,
body:not(.login-page):not(.welcome-page) .shil-page {
  background-image:
    linear-gradient(180deg, rgba(255,255,255,.72), rgba(255,255,255,.42)),
    var(--shil-main-bg-image),
    var(--shil-main-bg-overlay) !important;
  background-size: cover, cover, cover !important;
  background-position: center center, center center, center center !important;
  background-repeat: no-repeat, no-repeat, no-repeat !important;
  background-attachment: fixed, fixed, fixed !important;
}

/* Stronger target for dashboard/main internal containers */
body:not(.login-page):not(.welcome-page) [class*="dashboard"],
body:not(.login-page):not(.welcome-page) [class*="Dashboard"],
body:not(.login-page):not(.welcome-page) [class*="main"],
body:not(.login-page):not(.welcome-page) [class*="Main"],
body:not(.login-page):not(.welcome-page) [class*="project"],
body:not(.login-page):not(.welcome-page) [class*="Project"] {
  background-blend-mode: normal !important;
}

/* Exclusions: do not override Login and Welcome page backgrounds */
[class*="login"],
[class*="Login"],
[class*="welcome"],
[class*="Welcome"] {
  --shil-main-bg-image: initial;
}

/* If page root itself is login/welcome, preserve its own design */
[class*="login"].page,
[class*="Login"].page,
[class*="welcome"].page,
[class*="Welcome"].page,
[class*="login"].screen,
[class*="Login"].screen,
[class*="welcome"].screen,
[class*="Welcome"].screen,
[class*="login"].mobile-page,
[class*="Login"].mobile-page,
[class*="welcome"].mobile-page,
[class*="Welcome"].mobile-page {
  background-image: revert !important;
  background-size: revert !important;
  background-position: revert !important;
  background-repeat: revert !important;
  background-attachment: revert !important;
}

/* Mobile stability: fixed attachment can flicker on some browsers */
@media (max-width: 768px) {
  body:not(.login-page):not(.welcome-page) #root,
  body:not(.login-page):not(.welcome-page) .app,
  body:not(.login-page):not(.welcome-page) .shil-app,
  body:not(.login-page):not(.welcome-page) .mobile-app,
  body:not(.login-page):not(.welcome-page) .app-shell,
