body:not(.login-page):not(.welcome-page) .shil-page::after,
body:not(.login-page):not(.welcome-page) main::before,
body:not(.login-page):not(.welcome-page) main::after {
  display: none !important;
  content: none !important;
}

/* Remove all separator lines, borders, outlines, neon divider systems */
