  /* Block/card/section surface */
  --shil-block-bg: #f8fbfd;
  --shil-block-bg-strong: #ffffff;

  /* Fields / inputs / data cells */
  --shil-field-bg: #eef8fc;
  --shil-field-bg-strong: #f5fcff;

  /* Headers / footers */
  --shil-nav-bg: #4f5d6e;
  --shil-nav-bg-2: #435263;

  /* Buttons inside header/footer */
  --shil-nav-btn-bg: #edf8ff;
  --shil-nav-btn-bg-2: #dff0fa;

  /* Lines */
  --shil-block-border: #82d9f2;
  --shil-field-border: #42c2e6;
  --shil-soft-border: rgba(66, 194, 230, .42);

  /* Text */
  --shil-text: #0c2433;
  --shil-muted: #516b7a;
  --shil-white: #ffffff;

  /* Shadows */
  --shil-block-shadow:
    0 8px 20px rgba(14, 35, 55, .07),
    inset 0 1px 0 rgba(255,255,255,.96);

  --shil-field-shadow:
    0 4px 10px rgba(14, 35, 55, .045),
    inset 0 1px 0 rgba(255,255,255,.90);
}

