:root {
  --shil-safe-top: env(safe-area-inset-top);
  --shil-safe-bottom: env(safe-area-inset-bottom);
  --shil-bg: #071013;
  --shil-panel: rgba(12, 24, 29, 0.88);
  --shil-panel-soft: rgba(18, 37, 44, 0.72);
  --shil-border: rgba(80, 220, 196, 0.22);
  --shil-border-strong: rgba(80, 220, 196, 0.42);
  --shil-text: #edf7f5;
  --shil-muted: #9ab0ae;
  --shil-accent: #50dcc4;
  --shil-gold: #d5a447;
  --shil-danger: #ff7a7a;
  --header-h: 74px;
  --footer-h: 76px;
  color-scheme: dark;
}

* { box-sizing: border-box; }
html, body, #root { width: 100%; min-height: 100%; margin: 0; overflow-x: hidden; }
body {
  direction: rtl;
  font-family: Vazirmatn, IRANSans, "Segoe UI", Tahoma, sans-serif;
  background:
    radial-gradient(circle at 20% 0%, rgba(80, 220, 196, .18), transparent 32%),
    radial-gradient(circle at 90% 10%, rgba(213, 164, 71, .12), transparent 28%),
    linear-gradient(145deg, #061013 0%, #071013 45%, #0b171b 100%);
  color: var(--shil-text);
}
button, input, select, textarea { font: inherit; }
button { cursor: pointer; }

.shil-app { min-height: 100dvh; background: linear-gradient(rgba(0,0,0,.34), rgba(0,0,0,.58)); }
.shil-shell { min-height: 100dvh; position: relative; max-width: 480px; margin: 0 auto; overflow-x: hidden; }
.shil-main {
  min-height: 100dvh;
  padding: calc(var(--header-h) + 10px) 12px calc(var(--footer-h) + 16px);
  overflow-x: hidden;
}
.shil-header, .shil-footer {
  position: fixed; left: 50%; transform: translateX(-50%); width: min(100%, 480px); z-index: 20;
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  background: linear-gradient(180deg, rgba(5, 14, 17, .94), rgba(5, 14, 17, .72));
  border-color: var(--shil-border); border-style: solid;
}
.shil-header { top: 0; height: calc(var(--header-h) + var(--shil-safe-top)); padding: calc(var(--shil-safe-top) + 10px) 10px 8px; border-width: 0 0 1px; }
.shil-footer { bottom: 0; min-height: calc(var(--footer-h) + var(--shil-safe-bottom)); padding: 9px 10px calc(9px + var(--shil-safe-bottom)); border-width: 1px 0 0; }
.shil-header-row, .shil-footer-row { display: grid; grid-template-columns: 1fr auto 1fr; gap: 8px; align-items: center; }
.shil-brand { text-align: center; font-weight: 900; letter-spacing: .08em; line-height: 1; }
.shil-brand small { display: block; margin-top: 4px; color: var(--shil-muted); font-size: 10px; font-weight: 500; letter-spacing: 0; }
.shil-capsule, .shil-mini-btn, .shil-primary-btn, .shil-ghost-btn {
  border: 1px solid var(--shil-border); border-radius: 999px; color: var(--shil-text);
  background: rgba(15, 35, 41, .74); min-height: 38px; padding: 0 12px;
  box-shadow: 0 12px 28px rgba(0,0,0,.26), inset 0 1px 0 rgba(255,255,255,.05);
}
.shil-capsule { justify-self: end; display: inline-flex; align-items: center; max-width: 128px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 12px; }
.shil-mini-btn { justify-self: start; min-width: 42px; }
.shil-primary-btn { border-color: var(--shil-border-strong); background: linear-gradient(180deg, rgba(80,220,196,.22), rgba(18,51,55,.9)); color: #effffb; font-weight: 800; }
.shil-ghost-btn { color: var(--shil-muted); background: rgba(8,18,22,.7); }
.shil-footer-row { grid-template-columns: 1fr 1fr 1fr; }
.shil-footer-row button { width: 100%; font-size: 12px; }

.shil-panel, .shil-card {
  border: 1px solid var(--shil-border); border-radius: 20px; background: var(--shil-panel);
  box-shadow: 0 18px 48px rgba(0,0,0,.32), 0 0 0 1px rgba(255,255,255,.025) inset;
  padding: 12px; overflow: hidden;
}
.shil-panel + .shil-panel, .shil-section + .shil-section { margin-top: 10px; }
.shil-panel-title { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 10px; }
.shil-panel-title h2, .shil-panel-title h3 { margin: 0; font-size: 14px; }
.shil-panel-title span { color: var(--shil-muted); font-size: 11px; }
.shil-hero { min-height: 122px; display: grid; gap: 8px; align-content: center; text-align: center; }
.shil-hero h1 { margin: 0; font-size: 21px; line-height: 1.7; }
.shil-hero p { margin: 0; color: var(--shil-muted); font-size: 12px; }
.shil-grid { display: grid; gap: 10px; }
.shil-grid.cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.shil-grid.cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.shil-card { min-height: 104px; display: grid; place-items: center; text-align: center; gap: 6px; background: var(--shil-panel-soft); }
.shil-card.is-active { border-color: var(--shil-border-strong); box-shadow: 0 16px 42px rgba(80,220,196,.12); }
.shil-card-icon { width: 42px; height: 42px; display: grid; place-items: center; border-radius: 14px; background: linear-gradient(145deg, rgba(80,220,196,.22), rgba(213,164,71,.12)); border: 1px solid var(--shil-border); font-size: 22px; }
.shil-card-title { font-size: 12px; font-weight: 800; }
.shil-card-note { color: var(--shil-muted); font-size: 10px; line-height: 1.6; }
.shil-path-strip { display: flex; gap: 8px; overflow-x: auto; padding: 0 0 9px; scrollbar-width: thin; scrollbar-color: var(--shil-accent) rgba(255,255,255,.08); }
.shil-step-chip { flex: 0 0 auto; min-width: 86px; border: 1px solid var(--shil-border); border-radius: 16px; padding: 8px; text-align: center; background: rgba(9,20,24,.82); }
.shil-step-chip.active { border-color: var(--shil-gold); color: var(--shil-gold); }
.shil-step-chip b { display: block; font-size: 12px; }
.shil-step-chip span { display: block; color: var(--shil-muted); font-size: 10px; }
.shil-form { display: grid; gap: 9px; }
.shil-field label { display: block; margin-bottom: 5px; color: var(--shil-muted); font-size: 11px; }
.shil-input, .shil-select, .shil-textarea {
  width: 100%; min-height: 42px; border: 1px solid var(--shil-border); border-radius: 14px; padding: 8px 10px;
  background: rgba(5,15,19,.72); color: var(--shil-text); outline: none;
}
.shil-textarea { min-height: 72px; resize: vertical; }
.shil-metrics { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 8px; }
.shil-metric { border: 1px solid rgba(255,255,255,.08); border-radius: 16px; padding: 9px; background: rgba(255,255,255,.035); }
.shil-metric b { display: block; font-size: 16px; }
.shil-metric span { color: var(--shil-muted); font-size: 10px; }
.shil-map { height: 160px; border-radius: 18px; border: 1px solid var(--shil-border); background: radial-gradient(circle at 50% 45%, rgba(80,220,196,.28), transparent 34%), linear-gradient(135deg, rgba(80,220,196,.08), rgba(213,164,71,.08)); display: grid; place-items: center; text-align: center; }
.shil-map strong { font-size: 34px; }
.shil-warning { border: 1px solid rgba(213,164,71,.34); background: rgba(213,164,71,.08); color: #f8df9f; border-radius: 16px; padding: 10px; font-size: 12px; line-height: 1.8; }
@media (max-width: 360px) { .shil-main { padding-left: 8px; padding-right: 8px; } .shil-grid.cols-3 { gap: 7px; } .shil-card { min-height: 92px; } }


/* ===== SOURCE: src/styles/app.css ===== */
* {
