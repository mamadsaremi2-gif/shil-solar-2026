  margin: 0 0 12px;
}

h2 {
  margin: 0;
  font-size: 20px;
}

p {
  color: #bdd2d2;
  line-height: 1.8;
  margin: 0;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
}

.section-head span {
  color: #9ec4c2;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.dash-card {
  min-height: 132px;
  border-radius: 24px;
  border: 1px solid rgba(24, 184, 166, 0.32);
