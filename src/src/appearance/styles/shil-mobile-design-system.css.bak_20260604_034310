  }

  body.shil-route-dashboard .shil-ios-grid,
  body.shil-route-dashboard .new-project-grid-3x3,
  body.shil-route-dashboard .dashboard-icons,
  body.shil-route-dashboard [class*="icon-grid"] {
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 auto !important;
    padding: 0 !important;
