}

.primary-btn {
  width: 100%;
  height: 54px;
  border: none;
  border-radius: 20px;
  margin-top: 14px;
  background: #18c9b7;
  color: #001216;
  font-size: 17px;
  font-weight: 900;
}

.app-footer {
  position: fixed;
  bottom: 0;
  width: 100%;
  max-width: 430px;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10px;
  padding: 12px 14px calc(12px + env(safe-area-inset-bottom));
  background: rgba(0, 12, 18, 0.92);
  border-top: 1px solid rgba(24, 184, 166, 0.25);
  backdrop-filter: blur(8px);
}

.footer-btn {
  height: 48px;
  border-radius: 20px;
  background: rgba(255,255,255,.07);
  display: grid;
  place-items: center;
  font-weight: 700;
}


