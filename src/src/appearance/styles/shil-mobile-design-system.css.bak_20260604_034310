/* SHIL mobile-first product flow update - safe additive layer */
:root {
  --shil-header-h: 64px;
  --shil-footer-h: 62px;
  --shil-safe-x: clamp(16px, 5vw, 28px);
  --shil-glass: rgba(12, 18, 28, 0.54);
  --shil-border: rgba(255, 255, 255, 0.18);
  --shil-text: #f7fbff;
  --shil-muted: rgba(247, 251, 255, 0.72);
}

html, body, #root { min-height: 100%; overflow-x: hidden; }
body { margin: 0; background: #07101c; }
a { color: inherit; text-decoration: none; }
button, input, textarea, select { font: inherit; }

.shil-master-bg,
.shil-auth-page,
.shil-welcome-page,
.shil-dashboard-home,
.shil-page-shell {
  background-image: linear-gradient(180deg, rgba(4, 10, 19, 0.38), rgba(4, 10, 19, 0.78)), url('/assets/shil/background/main/shil-main-bg.svg');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.shil-master-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  filter: blur(4px) saturate(0.95);
  transform: scale(1.03);
}

.shil-dashboard-bg { filter: blur(5px) saturate(0.9); }

.shil-auth-page,
.shil-welcome-page,
.shil-dashboard-home,
.shil-page-shell {
  position: relative;
  min-height: 100dvh;
  color: var(--shil-text);
  overflow: hidden;
}

.shil-auth-card {
  position: absolute;
  inset-inline: var(--shil-safe-x);
  top: 50%;
  transform: translateY(-50%);
  max-width: 430px;
  margin-inline: auto;
  padding: 24px;
  border: 1px solid var(--shil-border);
  border-radius: 28px;
  background: rgba(8, 16, 28, 0.72);
  backdrop-filter: blur(18px);
  box-shadow: 0 22px 70px rgba(0, 0, 0, 0.35);
}

.shil-auth-brand { display: grid; gap: 8px; text-align: center; margin-bottom: 18px; }
.shil-auth-brand strong { font-size: 32px; letter-spacing: 0.18em; }
.shil-auth-brand span { color: var(--shil-muted); line-height: 1.8; }
.shil-auth-tabs { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 14px; }
.shil-auth-tabs button,
.shil-auth-form button,
.shil-guest-btn,
.shil-primary-entry {
  border: 0;
  border-radius: 16px;
  padding: 13px 16px;
  color: var(--shil-text);
  background: rgba(255, 255, 255, 0.12);
  cursor: pointer;
}
.shil-auth-tabs button.active,
.shil-auth-form button,
.shil-primary-entry { background: linear-gradient(135deg, #0ea5e9, #22c55e); }
.shil-auth-form { display: grid; gap: 10px; }
.shil-auth-form input,
.shil-assistant-form textarea,
.shil-feedback-form textarea,
.shil-feedback-form select {
  width: 100%;
  box-sizing: border-box;
  border: 1px solid rgba(255, 255, 255, 0.14);
  border-radius: 16px;
  color: var(--shil-text);
  background: rgba(0, 0, 0, 0.26);
  padding: 13px 14px;
  outline: none;
}
.shil-auth-error { color: #fecaca; margin: 0; font-size: 13px; }
.shil-guest-btn { width: 100%; margin-top: 10px; background: rgba(255, 255, 255, 0.1); }

.shil-welcome-glass-header {
  position: fixed;
  top: max(14px, env(safe-area-inset-top));
  inset-inline: var(--shil-safe-x);
  z-index: 2;
  min-height: 52px;
  display: grid;
  place-items: center;
  text-align: center;
  padding: 8px 18px;
  border: 1px solid var(--shil-border);
  border-radius: 22px;
  background: rgba(255, 255, 255, 0.09);
  backdrop-filter: blur(18px);
  font-weight: 800;
  line-height: 1.7;
}
.shil-welcome-center { min-height: 100dvh; display: grid; place-items: center; align-content: center; gap: 32px; padding: 24px; }
.shil-welcome-logo { width: min(42vw, 220px); aspect-ratio: 1; object-fit: contain; animation: shilLogoFloat 4s ease-in-out infinite; filter: drop-shadow(0 24px 50px rgba(14, 165, 233, 0.35)); }
@keyframes shilLogoFloat { 0%,100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-12px) scale(1.04); } }

.shil-dashboard-home { display: grid; place-items: center; padding: calc(env(safe-area-inset-top) + 46px) var(--shil-safe-x) calc(env(safe-area-inset-bottom) + 32px); }
.shil-online-chip {
  position: fixed;
  top: max(16px, env(safe-area-inset-top));
  right: var(--shil-safe-x);
  z-index: 3;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 7px 11px;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.28);
  backdrop-filter: blur(12px);
  font-size: 12px;
}
.shil-online-chip span { width: 9px; height: 9px; border-radius: 50%; background: #ef4444; box-shadow: 0 0 12px #ef4444; }
.shil-online-chip[data-online="true"] span { background: #22c55e; box-shadow: 0 0 16px #22c55e; animation: shilPulse 1.7s ease-in-out infinite; }
@keyframes shilPulse { 0%,100% { opacity: 0.65; transform: scale(0.92); } 50% { opacity: 1; transform: scale(1.1); } }

.shil-ios-grid {
  position: relative;
  z-index: 1;
  width: min(100%, 520px);
  margin-inline: auto;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: clamp(22px, 5vh, 38px) clamp(24px, 8vw, 48px);
  align-items: center;
  justify-items: center;
}
.shil-ios-icon-link {
  display: grid;
  justify-items: center;
  align-content: start;
  gap: 8px;
  min-width: 0;
  color: var(--shil-text);
  text-align: center;
  -webkit-tap-highlight-color: transparent;
  transition: transform 160ms ease, filter 160ms ease;
}
.shil-ios-icon-link:active { transform: scale(0.94); }
.shil-ios-icon-img {
  width: clamp(54px, 14vw, 78px);
  height: clamp(54px, 14vw, 78px);
  display: grid;
  place-items: center;
  color: #f8fafc;
  filter: drop-shadow(0 12px 22px rgba(0, 0, 0, 0.45));
}
.shil-ios-icon-img img { width: 100%; height: 100%; object-fit: contain; }
.shil-ios-icon-title {
  max-width: 96px;
  min-height: 34px;
  font-size: clamp(11px, 3.2vw, 14px);
  font-weight: 800;
  line-height: 1.55;
  text-shadow: 0 2px 12px rgba(0, 0, 0, 0.72);
}
.dashboard-icons { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.new-project-grid-3x3 { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: clamp(14px, 3.4vh, 28px) clamp(12px, 5vw, 28px); }
.new-project-grid-3x3 .shil-ios-icon-img { width: clamp(46px, 13vw, 68px); height: clamp(46px, 13vw, 68px); }

.shil-fixed-header,
.shil-fixed-footer {
  position: fixed;
  z-index: 5;
  inset-inline: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding-inline: var(--shil-safe-x);
  background: rgba(9, 18, 31, 0.66);
  border-color: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(16px);
}
.shil-fixed-header { top: 0; height: calc(var(--shil-header-h) + env(safe-area-inset-top)); padding-top: env(safe-area-inset-top); border-bottom: 1px solid rgba(255,255,255,0.12); }
.shil-fixed-footer { bottom: 0; height: calc(var(--shil-footer-h) + env(safe-area-inset-bottom)); padding-bottom: env(safe-area-inset-bottom); border-top: 1px solid rgba(255,255,255,0.12); justify-content: space-around; }
.shil-header-title { max-width: 52vw; padding: 8px 14px; border-radius: 999px; background: rgba(255,255,255,0.1); font-weight: 900; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.shil-header-action,
.shil-fixed-footer a { border: 0; color: var(--shil-text); background: rgba(255,255,255,0.08); border-radius: 999px; padding: 8px 12px; font-size: 12px; }
.shil-page-content { position: relative; z-index: 1; min-height: calc(100dvh - var(--shil-header-h) - var(--shil-footer-h)); padding: calc(var(--shil-header-h) + env(safe-area-inset-top) + 18px) var(--shil-safe-x) calc(var(--shil-footer-h) + env(safe-area-inset-bottom) + 18px); overflow-y: auto; box-sizing: border-box; }
.shil-new-project-no-scroll .shil-page-content { display: grid; place-items: center; overflow: hidden; }

.shil-two-card-grid,
.shil-three-card-grid { display: grid; gap: 16px; align-items: stretch; }
.shil-two-card-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.shil-three-card-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.shil-nav-card,
.shil-info-panel,
.shil-list-panel,
.shil-contact-banner,
