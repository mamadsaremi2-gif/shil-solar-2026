/* =========================================================
   SHIL FINAL BACKGROUND VISIBLE + INNER MATTE GLASS
   1) Dashboard / New Project: no glass panels at all, only icons on main background.
   2) Other pages: no solid white page background; main background must be visible.
   3) Only inner cards/blocks get semi-matte glass.
   4) Remove remaining separator/border/neon lines.
   ========================================================= */

:root {
  --shil-main-bg-url: url('/assets/shil/background/main/shil-main-bg.webp');
  --shil-bg-fallback: #dfe7ee;

  --shil-inner-glass: rgba(255,255,255,.34);
  --shil-inner-glass-strong: rgba(255,255,255,.44);
  --shil-field-glass: rgba(255,255,255,.26);
  --shil-field-glass-strong: rgba(255,255,255,.36);

  --shil-soft-shadow: 0 16px 38px rgba(12,28,46,.11), inset 0 1px 0 rgba(255,255,255,.46);
  --shil-field-shadow: 0 8px 20px rgba(12,28,46,.065), inset 0 1px 0 rgba(255,255,255,.38);

  --shil-text: #0d2535;
  --shil-muted: #526a78;
}

/* Main background visible globally */
html,
body,
#root {
  min-height: 100% !important;
  background-color: var(--shil-bg-fallback) !important;
}

body:not(.login-page):not(.welcome-page),
body:not(.login-page):not(.welcome-page) #root,
body:not(.login-page):not(.welcome-page) .app,
body:not(.login-page):not(.welcome-page) .shil-app,
body:not(.login-page):not(.welcome-page) .mobile-app,
body:not(.login-page):not(.welcome-page) .app-shell,
body:not(.login-page):not(.welcome-page) .shil-shell,
body:not(.login-page):not(.welcome-page) .mobile-shell,
body:not(.login-page):not(.welcome-page) .page,
body:not(.login-page):not(.welcome-page) .screen,
body:not(.login-page):not(.welcome-page) .mobile-page,
body:not(.login-page):not(.welcome-page) .shil-page,
body:not(.login-page):not(.welcome-page) .shil-main,
body:not(.login-page):not(.welcome-page) main {
  background-color: var(--shil-bg-fallback) !important;
  background-image: var(--shil-main-bg-url) !important;
  background-size: cover !important;
  background-position: center center !important;
  background-repeat: no-repeat !important;
  background-attachment: fixed !important;
  color: var(--shil-text) !important;
}

/* Remove any white page canvas overlays so bg remains visible */
body:not(.login-page):not(.welcome-page) .page::before,
body:not(.login-page):not(.welcome-page) .page::after,
body:not(.login-page):not(.welcome-page) .screen::before,
