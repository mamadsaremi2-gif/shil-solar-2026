/* ===== CANONICAL SHIL MOBILE OVERRIDE LAYER ===== */
/* =========================================================
   SHIL MOBILE DESIGN SYSTEM REFERENCE
   ---------------------------------------------------------
   This file is the central visual reference for SHIL mobile UI.
   Keep all shared mobile layout, header, footer, cards, forms,
   step-path, dashboard, and responsive rules here.
   ========================================================= */

/* =========================================================
   0) Design Tokens / Global Mobile Safety
   ========================================================= */
:root {
  --shil-page-bg: #f6f2ff;
  --shil-surface: rgba(255, 255, 255, 0.18);
  --shil-surface-strong: rgba(255, 255, 255, 0.3);
  --shil-surface-dark: rgba(0, 0, 0, 0.22);
  --shil-border: rgba(255, 255, 255, 0.28);
  --shil-border-strong: rgba(255, 255, 255, 0.35);
  --shil-text: #24114f;
  --shil-text-muted: rgba(36, 17, 79, 0.65);
  --shil-text-inverse: #ffffff;
  --shil-primary: #7b42ff;
  --shil-primary-2: #b05cff;
  --shil-success: #079455;
  --shil-success-dot: #18c37e;
  --shil-accent-mint: #50dcc4;

  --shil-header-top: 12px;
  --shil-side-gap: 12px;
  --shil-header-height: 64px;
  --shil-footer-bottom: 12px;
  --shil-footer-height: 72px;
  --shil-radius-lg: 28px;
  --shil-radius-md: 24px;
  --shil-radius-sm: 16px;
  --shil-blur: 18px;
  --shil-shadow-top: 0 8px 30px rgba(0, 0, 0, 0.08);
  --shil-shadow-bottom: 0 -8px 26px rgba(0, 0, 0, 0.08);
  --shil-shadow-card: 0 14px 32px rgba(0, 0, 0, 0.14);

  --shil-content-top-safe: calc(var(--shil-header-top) + var(--shil-header-height) + 16px);
  --shil-content-bottom-safe: calc(var(--shil-footer-bottom) + var(--shil-footer-height) + 20px);
}

* {
  box-sizing: border-box;
}

html,
body,
#root {
  width: 100%;
  min-height: 100%;
  margin: 0;
  overflow-x: hidden;
}

body {
  background: var(--shil-page-bg);
  color: var(--shil-text);
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

img,
svg,
video,
canvas {
  max-width: 100%;
}

button,
input,
select,
textarea {
  font: inherit;
}

/* =========================================================
   1) Frame / Fixed Bars Layout
   ========================================================= */
.shil-frame {
  width: 100%;
  min-height: 100vh;
  position: relative;
  overflow-x: hidden;
}

.shil-frame-main {
  width: 100%;
  min-height: 100vh;
  padding-top: var(--shil-content-top-safe) !important;
  padding-bottom: var(--shil-content-bottom-safe) !important;
  padding-left: var(--shil-side-gap);
  padding-right: var(--shil-side-gap);
  overflow-x: hidden;
}

.shil-page-scroll {
  width: 100%;
  max-width: 100%;
  overflow-x: hidden;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.shil-safe-content {
  width: 100%;
  max-width: 100%;
  margin: 0 auto;
}

/* =========================================================
   2) Fixed Header
   ========================================================= */
.shil-header {
  position: fixed;
  top: var(--shil-header-top);
  left: var(--shil-side-gap);
  right: var(--shil-side-gap);
  height: var(--shil-header-height);
  z-index: 2000;

  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;

  padding: 0 14px;
  border-radius: var(--shil-radius-md);

  background: var(--shil-surface);
  backdrop-filter: blur(var(--shil-blur));
  -webkit-backdrop-filter: blur(var(--shil-blur));

  border: 1px solid var(--shil-border);
  box-shadow: var(--shil-shadow-top);
}

.shil-header-title {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--shil-text);
  line-height: 1.35;
  text-align: center;
}

.shil-header-title strong {
  max-width: 100%;
  font-size: 14px;
  font-weight: 800;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.shil-header-title span {
  max-width: 100%;
  font-size: 10px;
  opacity: 0.65;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.shil-header-status {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 5px;
  color: var(--shil-success);
  font-size: 11px;
  font-weight: 700;
  white-space: nowrap;
}

.shil-header-status i {
  width: 8px;
  height: 8px;
  background: var(--shil-success-dot);
  border-radius: 50%;
  display: block;
  box-shadow: 0 0 10px rgba(24, 195, 126, 0.8);
}

/* =========================================================
   3) Fixed Footer / Step Actions
   ========================================================= */
.shil-footer {
  position: fixed;
  left: var(--shil-side-gap);
  right: var(--shil-side-gap);
  bottom: var(--shil-footer-bottom);
  min-height: var(--shil-footer-height);
  z-index: 2000;

  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;

  padding: 10px 12px;
  border-radius: var(--shil-radius-lg);

  background: var(--shil-surface);
  backdrop-filter: blur(var(--shil-blur));
  -webkit-backdrop-filter: blur(var(--shil-blur));

  border: 1px solid var(--shil-border);
  box-shadow: var(--shil-shadow-bottom);
}

.shil-footer-btn,
.shil-header-btn {
  border: 1px solid var(--shil-border-strong);
  background: var(--shil-surface-strong);
  color: var(--shil-text);
  font-weight: 700;
  border-radius: var(--shil-radius-sm);
  padding: 8px 12px;
  min-height: 38px;
  cursor: pointer;
  transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease, background 140ms ease;
  -webkit-tap-highlight-color: transparent;
}

.shil-footer-btn {
  flex: 1;
  min-width: 0;
  font-size: 12px;
  text-align: center;
  white-space: nowrap;
}

.shil-header-btn {
  flex: 0 0 auto;
  max-width: 96px;
  font-size: 12px;
  white-space: nowrap;
}

.shil-footer-btn:active,
.shil-header-btn:active,
.shil-soft-button:active {
  transform: translateY(1px) scale(0.98);
}

.shil-footer-primary,
.shil-primary-button {
  color: var(--shil-text-inverse) !important;
  background: linear-gradient(135deg, var(--shil-primary), var(--shil-primary-2)) !important;
  box-shadow: 0 0 20px rgba(123, 66, 255, 0.45);
}

/* =========================================================
   4) Horizontal Design Step Path
   ========================================================= */
.shil-step-path {
  width: 100%;
  max-width: 100%;
  display: flex;
  align-items: center;
  gap: 8px;
  overflow-x: auto;
  overflow-y: hidden;
  padding: 6px 2px 10px;
  margin: 0 0 10px;
  scroll-snap-type: x proximity;
  -webkit-overflow-scrolling: touch;
}

.shil-step-path::-webkit-scrollbar {
  display: none;
}

.shil-step-item {
  flex: 0 0 auto;
  min-width: 58px;
  max-width: 78px;
  scroll-snap-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  text-align: center;
  color: var(--shil-text);
  font-size: 10px;
  line-height: 1.35;
}

.shil-step-icon {
  width: 38px;
  height: 38px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  background: rgba(255, 255, 255, 0.26);
  border: 1px solid var(--shil-border);
  box-shadow: 0 8px 18px rgba(0, 0, 0, 0.06);
}

.shil-step-item.active .shil-step-icon {
  color: var(--shil-text-inverse);
  background: linear-gradient(135deg, var(--shil-primary), var(--shil-primary-2));
}

/* =========================================================
   5) Cards / Grids / Dashboard Cubes
   ========================================================= */
.shil-card,
.shil-bank-card,
.shil-dashboard-card {
  width: 100%;
  max-width: 100%;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--shil-radius-md);
  padding: 12px;
  background: rgba(255, 255, 255, 0.045);
  box-shadow: var(--shil-shadow-card);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  overflow: hidden;
}

.shil-card-title {
  margin: 0 0 8px;
  font-size: 14px;
  font-weight: 800;
  text-align: center;
  color: inherit;
}

.shil-card-text {
  margin: 0;
  font-size: 12px;
  line-height: 1.8;
  text-align: center;
  color: inherit;
  opacity: 0.78;
}

.shil-grid-2,
.shil-grid-3,
.shil-system-banks-grid,
.shil-dashboard-grid {
  width: 100%;
  display: grid;
  gap: 12px;
}

.shil-grid-2 {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.shil-grid-3,
.shil-system-banks-grid,
.shil-dashboard-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.shil-dashboard-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  text-align: center;
  min-height: 108px;
}

.shil-dashboard-cube {
  width: 54px;
  height: 54px;
  border-radius: 18px;
  display: grid;
  place-items: center;
  background: linear-gradient(145deg, rgba(255,255,255,.36), rgba(255,255,255,.12));
  border: 1px solid var(--shil-border);
  box-shadow: 0 12px 22px rgba(0,0,0,.12), inset 0 1px 0 rgba(255,255,255,.28);
}

/* =========================================================
   6) Forms / Inputs / Bank Settings
   ========================================================= */
.shil-form,
.shil-system-settings-mini {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.shil-field,
.shil-bank-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-top: 10px;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.76);
}

.shil-field input,
.shil-field select,
.shil-field textarea,
.shil-bank-field select,
.shil-bank-field input {
  width: 100%;
  min-width: 0;
  border: 1px solid rgba(255, 255, 255, 0.14);
  border-radius: var(--shil-radius-sm);
  padding: 10px 12px;
  background: var(--shil-surface-dark);
  color: #fff;
  outline: none;
}

.shil-field textarea {
  min-height: 88px;
  resize: vertical;
}

.shil-field input:focus,
.shil-field select:focus,
.shil-field textarea:focus,
.shil-bank-field select:focus,
.shil-bank-field input:focus {
  border-color: rgba(80, 220, 196, 0.55);
  box-shadow: 0 0 0 3px rgba(80, 220, 196, 0.12);
}

.shil-bank-meta,
.shil-meta-box {
  margin-top: 10px;
  border-radius: var(--shil-radius-sm);
  padding: 9px 10px;
  background: rgba(80, 220, 196, 0.08);
  font-size: 11px;
  line-height: 1.9;
  color: rgba(255, 255, 255, 0.78);
}

/* =========================================================
   7) Buttons / Actions / Muted Lines
   ========================================================= */
.shil-action-row {
  display: flex;
  gap: 8px;
  align-items: center;
  justify-content: flex-start;
  flex-wrap: wrap;
  margin-top: 12px;
}

.shil-soft-button {
  border: 1px solid rgba(255, 255, 255, 0.18);
  background: rgba(255, 255, 255, 0.08);
  color: inherit;
  border-radius: var(--shil-radius-sm);
  padding: 9px 12px;
  min-height: 38px;
  cursor: pointer;
  transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
}

.shil-soft-button.active {
  border-color: rgba(80, 220, 196, 0.55);
  box-shadow: 0 0 18px rgba(80, 220, 196, 0.14);
}

.shil-muted-line {
  margin: 0;
  color: rgba(255, 255, 255, 0.72);
  font-size: 13px;
  line-height: 2;
}

/* =========================================================
   8) Data-heavy Pages / Summary / Output
   ========================================================= */
.shil-compact-stack {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.shil-data-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 8px;
  align-items: center;
  padding: 8px 10px;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.08);
  font-size: 12px;
  line-height: 1.6;
}

.shil-data-row strong,
.shil-data-row span {
  min-width: 0;
  overflow-wrap: anywhere;
}

.shil-map-fit,
.shil-output-image,
.shil-preview-image {
  width: 100%;
  max-width: 100%;
  height: auto;
  object-fit: contain;
  display: block;
}

/* =========================================================
   9) Responsive Rules
   ========================================================= */
@media (max-width: 760px) {
  .shil-system-banks-grid,
  .shil-grid-3 {
    grid-template-columns: 1fr;
  }

  .shil-bank-card,
