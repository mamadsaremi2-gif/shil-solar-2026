    width: 100vw !important;
    max-width: 100vw !important;
    min-height: 100dvh !important;
    height: 100dvh !important;
    margin: 0 !important;
    padding: 10px var(--shil-side-gap) calc(14px + env(safe-area-inset-bottom, 0px)) !important;
    overflow-y: auto !important;
    overflow-x: hidden !important;
    background: linear-gradient(180deg, #07111a 0%, #31404a 52%, #07111a 100%) !important;
  }

  body.shil-route-dashboard .shil-master-bg,
  body.shil-route-dashboard .shil-home-icons::before,
  body.shil-route-dashboard .shil-home-icons::after,
  body.shil-route-dashboard .new-project-grid-3x3::before,
