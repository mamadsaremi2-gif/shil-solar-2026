/* ============================================================
   SHIL MOBILE FINAL PATCH 2026-06-04
   Rules applied from mobile screenshots and user review:
   - Dashboard is full-screen mobile-first and has no header/footer.
   - Dashboard icons/images are NOT glassed; they sit directly on background.
   - Header and footer are minimal transparent glass on inner pages only.
   - Step rail is compact, transparent glass, tangent to header.
   - Page content scrolls under rail, but final data stops above footer.
   - Unified field/card colors and strict side gutters.
============================================================ */

@media (max-width: 768px) {
  :root {
    --shil-mobile-w: 100vw;
    --shil-side-gap: 10px;
    --shil-header-h: 52px;
    --shil-rail-h: 68px;
    --shil-footer-h: 72px;
    --shil-top-stack: calc(var(--shil-header-h) + var(--shil-rail-h));
    --shil-bottom-safe: calc(var(--shil-footer-h) + env(safe-area-inset-bottom, 0px) + 14px);
    --shil-glass: rgba(232, 244, 255, .30);
    --shil-glass-strong: rgba(232, 244, 255, .42);
    --shil-glass-border: rgba(255, 255, 255, .28);
    --shil-card-bg: rgba(246, 252, 255, .94);
    --shil-field-bg: rgba(255, 255, 255, .92);
    --shil-field-border: rgba(72, 218, 215, .48);
    --shil-text: #071728;
  }

  html,
  body,
  #root {
    width: 100vw !important;
    min-width: 100vw !important;
    max-width: 100vw !important;
    height: 100dvh !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: hidden !important;
    background: #04101a !important;
  }

  #root,
  .app,
  .shil-frame,
  .shil-page-shell,
  .shil-dashboard-shell,
  .dashboard-shell-v15,
  [class*="shell"],
  [class*="page"] {
    max-width: 100vw !important;
    width: 100vw !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    box-sizing: border-box !important;
  }

  body:not(.login-page):not(.welcome-page) .shil-frame,
  body:not(.login-page):not(.welcome-page) .shil-page-shell {
    height: 100dvh !important;
    min-height: 100dvh !important;
    overflow: hidden !important;
    background: linear-gradient(180deg, #04101a 0%, #09233c 50%, #04101a 100%) !important;
  }

  /* Dashboard: no chrome, no empty desktop margins, no icon glass. */
  body.shil-route-dashboard .shil-header,
  body.shil-route-dashboard .shil-footer,
  body.shil-route-dashboard .shil-fixed-header,
  body.shil-route-dashboard .shil-fixed-footer,
