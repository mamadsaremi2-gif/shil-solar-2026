{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@data/*": ["src/data/*"],
      "@engines/*": ["src/engines/*"],
      "@calculation/*": ["src/calculation/*"]
    }
  },
  "include": ["src/**/*.js", "tests/**/*.js"]
}
